# ===========================================
# TEAM-5 Speech Analysis Pipeline
# Environment Configuration
# ===========================================
# Copy this file to .env and fill in your API key:
#   cp .env.example .env
#
# Get your FREE Gemini API key at:
#   https://aistudio.google.com/apikey
# ===========================================

# Google Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override default model (default: gemini-2.0-flash)
# GEMINI_MODEL_NAME=gemini-2.0-flash

# Optional: Override LLM temperature (default: 0.3)
# LLM_TEMPERATURE=0.3

# Optional: Override max output tokens (default: 1024)
# LLM_MAX_TOKENS=1024
