# ===========================================
# TEAM-5 Speech Analysis Pipeline
# Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in your API key:
#   cp .env.example .env
#
# Get your FREE NVIDIA NIM API key at:
#   https://build.nvidia.com/
# ===========================================

# NVIDIA NIM API Key (Required)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: Override default model (default: meta/llama-3.1-70b-instruct)
# NVIDIA_MODEL_NAME=meta/llama-3.1-70b-instruct

# Optional: Override LLM temperature (default: 0.3)
# LLM_TEMPERATURE=0.3

# Optional: Override max output tokens (default: 1024)
# LLM_MAX_TOKENS=1024
